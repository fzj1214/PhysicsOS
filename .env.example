# PhysicsOS OpenAI-compatible model config.
# Fill this value yourself. Do not commit real keys.
PHYSICSOS_OPENAI_API_KEY=

# For most OpenAI-compatible SDKs, base_url should point at the API root that
# contains /chat/completions or /responses underneath.
# Base URL should be the /v1 API root. LangChain/OpenAI SDK appends
# /chat/completions or /responses depending on mode.
PHYSICSOS_OPENAI_BASE_URL=https://api.tu-zi.com/v1
PHYSICSOS_OPENAI_MODEL=gpt-5.4
PHYSICSOS_DEEPSEARCH_MODEL=gemini-3-pro-deepsearch-async

# Set true because this provider supports OpenAI-compatible /v1/responses.
PHYSICSOS_OPENAI_USE_RESPONSES_API=true

# Optional local surrogate registry override.
PHYSICSOS_SURROGATE_REGISTRY=configs/surrogates.local.json
