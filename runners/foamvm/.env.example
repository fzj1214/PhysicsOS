# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_OUTPUT_BUCKET=run-outputs

# E2B
E2B_API_KEY=your-e2b-api-key
E2B_TEMPLATE_ID=your-e2b-template-id

# Optional bearer token required by POST /api/physicsos/jobs
PHYSICSOS_RUNNER_TOKEN=your-physicsos-runner-token

# Claude provider
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_BASE_URL=https://api.your-provider.example
